# Copy this file to .env and fill in real values. Never commit .env.

# Standard first-party Anthropic API key. Fine for synthetic/de-identified
# data now. Do not send real PHI through this key until a BAA-covered
# deployment path is in place (CLAUDE.md section 2).
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-5 if unset (CLAUDE.md section 2).
MEDILENS_MODEL_NAME=

# Host port Docker publishes Postgres on. Change to a free port (for example
# 5433) if this machine already runs Postgres on 5432, then update the port in
# DATABASE_URL below to match. docker compose reads this value from .env.
MEDILENS_DB_HOST_PORT=5432

# Matches docker-compose.yml's postgres service for local dev. If you change
# MEDILENS_DB_HOST_PORT above, change the port here too.
DATABASE_URL=postgresql+psycopg://medilens:medilens_dev_only@localhost:5432/medilens

# Client-side rate limits. Defaults are conservative (50 rpm, 30000 tpm).
# Set these to match your account tier per https://docs.claude.com/en/api/rate-limits
MEDILENS_MAX_REQUESTS_PER_MINUTE=
MEDILENS_MAX_TOKENS_PER_MINUTE=

# Copy this file to .env and fill in real values. Never commit .env.

# Standard first-party Anthropic API key. Fine for synthetic/de-identified
# data now. Do not send real PHI through this key until a BAA-covered
# deployment path is in place (CLAUDE.md section 2).
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-5 if unset (CLAUDE.md section 2).
MEDILENS_MODEL_NAME=

# Matches docker-compose.yml's postgres service for local dev.
DATABASE_URL=postgresql+psycopg://medilens:medilens_dev_only@localhost:5432/medilens
